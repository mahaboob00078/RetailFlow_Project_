n","    order_id = random.randint(20001, 24000)\n","\n","    # Small number of invalid product IDs\n","    if random.random() < 0.005:\n","        product_id = random.randint(900, 1000)\n","    else:\n","        product_id = random.randint(1, 800)\n","\n","    # Small number of invalid quantities\n","    if random.random() < 0.005:\n","        quantity = random.choice([0, -1, -2])\n","    else:\n","        quantity = random.randint(1, 5)\n","\n","    if product_id <= 800:\n","        unit_price = float(\n","            df_products.loc[\n","                df_products[\"product_id\"] == product_id,\n","                \"unit_price\"\n","            ].iloc[0]\n","        )\n","    else:\n","        unit_price = round(random.uniform(5, 1000), 2)\n","\n","    line_total = round(quantity * unit_price, 2)\n","\n","    order_items_day2.append({\n","        \"order_id\": order_id,\n","        \"product_id\": product_id,\n","        \"quantity\": quantity,\n","        \"unit_price\": unit_price,\n","        \"line_total\": line_total\n","    })\n","\n","df_order_items_day2 = pd.DataFrame(order_items_day2)\n","\n","df_order_items_day2.head()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":206},"id":"CftDVd1OMbVV","executionInfo":{"status":"ok","timestamp":1783438102295,"user_tz":-330,"elapsed":3095,"user":{"displayName":"mahaboobbasha amudam","userId":"09172580655464588444"}},"outputId":"750d0f22-66b4-4eb3-d078-4ae0d3758b37"},"execution_count":32,"outputs":[{"output_type":"execute_result","data":{"text/plain":["   order_id  product_id  quantity  unit_price  line_total\n","0     20125         280         4      747.47     2989.88\n","1     20360         393         1      941.86      941.86\n","2     23850         697         2      832.32     1664.64\n","3     20883         240         2      733.81     1467.62\n","4     22843         465         3      629.08     1887.24"],"text/html":["\n","  <div id=\"df-853a1b98-2eae-4da0-9aaa-5462180dd1db\" class=\"c