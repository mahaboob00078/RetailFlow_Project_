:{"displayName":"mahaboobbasha amudam","userId":"09172580655464588444"}},"outputId":"b309f6a9-2ff8-4a8f-8110-0cab3cd531bd"},"execution_count":48,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["# Merge order items with products\n","category_revenue = df_order_items_day1.merge(\n","    df_products[[\"product_id\", \"category\"]],\n","    on=\"product_id\",\n","    how=\"left\"\n",")\n","\n","# Calculate revenue by category\n","top_categories = (\n","    category_revenue\n","    .groupby(\"category\")[\"line_total\"]\n","    .sum()\n","    .sort_values(ascending=False)\n","    .head(10)\n",")\n","\n","# Plot\n","plt.figure(figsize=(10,6))\n","\n","top_categories.plot(kind=\"bar\")\n","\n","plt.title(\"Top 10 Categories by Revenue\")\n","plt.xlabel(\"Category\")\n","plt.ylabel(\"Revenue\")\n","\n","plt.xticks(rotation=45)\n","\n","plt.tight_layout()\n","\n","plt.savefig(\"RetailFlow_Data/top10_categories_by_revenue.png\")\n","\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":607},"id":"DkTnYHx_UH-y","executionInfo":{"status":"ok","timestamp":1783440118775,"user_tz":-330,"elapsed":943,"user":{"displayName":"mahaboobbasha amudam","userId":"09172580655464588444"}},"outputId":"bd42720d-3870-408c-eac6-354c6ad24653"},"execution_count":49,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["import pandas as pd\n","import seaborn as sns\n","import matplotlib.pyplot as plt\n","\n","datasets = {\n","    \"customers\": customers,\n","    \"products\": products,\n","    \"orders_day1\": orders_day1,\n","    \"order_items_day1\": order_items_day1,\n","    \"orders_day2\": orders_day2,\n","    \"order_items_day2\": order_items_day2,\n","    \"clickstream_day1\": clickstream_day1,\n","    \"clickstream_day2\": clickstream_day2\n","}\n","\n","null_rates = {}\n","\n","for name, df in datasets.items():\n","    null_rates[name] = df.isnull().mean() * 100\n","\n","null_df = pd.DataFrame(null_rates).T\n","\n","plt.figure(figsize=(14,8))\n","\n","sns.heatmap(\n","    null_df,\n","    annot=True,\n","    cmap=\"YlOrRd\",\n","    fmt=\".2f\"\n",")\n","\n","plt.title(\"Null Rate Heatmap (%)\")\n","\n","plt.tight_layout()\n","\n","plt.savefig(\"RetailFlow_Data/null_rate_heatmap.png\")\n","\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":807},"id":"xbTfVicgUI7R","executionInfo":{"status":"ok","timestamp":1783440498367,"user_tz":-330,"elapsed":1589,"user":{"displayName":"mahaboobbasha amudam","userId":"09172580655464588444"}},"outputId":"a2804afd-3e4d-4869-8fa4-34417d1329ad"},"execution_count":51,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1400x800 with 2 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["report = \"\"\"\n","# Data Profile Report\n","\n","## Project\n","RetailFlow Lakehouse - Phase 1\n","\n","## Dataset Summary\n","\n","- customers.csv - 5000 records\n","- products.csv - 800 records\n","- orders_day1.json - 20000 records\n","- order_items_day1.json - 55000 records\n","- orders_day2.json - 4000 records\n","- order_items_day2.json - 11000 records\n","- clickstream_day1.json - 15000 records\n","- clickstream_day2.json - 15000 records\n","\n","## Data Quality Checks\n","- Checked null values\n","- Checked duplicate records\n","- Verified data types\n","- Verified value ranges\n","\n","## Charts Created\n","1. Order Volume by Day\n","2. Revenue Distribution\n","3. Top 10 Categories by Revenue\n","4. Null-rate Heatmap\n","\"\"\"\n","\n","with open(\"RetailFlow_Data/data_profile_report.md\", \"w\") as f:\n","    f.write(report)\n","\n","print(\"data_profile_report.md created successfully!\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"tZg-wnnBWVpA","executionInfo":{"status