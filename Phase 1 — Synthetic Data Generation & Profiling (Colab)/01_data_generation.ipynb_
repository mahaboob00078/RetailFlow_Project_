der_id,\n","        \"product_id\": product_id,\n","        \"quantity\": quantity,\n","        \"unit_price\": unit_price,\n","        \"line_total\": line_total\n","    })\n","\n","df_order_items_day1 = pd.DataFrame(order_items)\n","\n","df_order_items_day1.head()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":206},"id":"kDYHfyH4Lylr","executionInfo":{"status":"ok","timestamp":1783437954588,"user_tz":-330,"elapsed":21876,"user":{"displayName":"mahaboobbasha amudam","userId":"09172580655464588444"}},"outputId":"faa32be7-b8b6-4633-b4fc-3076d7e134fb"},"execution_count":25,"outputs":[{"output_type":"execute_result","data":{"text/plain":["   order_id  product_id  quantity  unit_price  line_total\n","0      3263          59         3      359.75     1079.25\n","1     13187         698         5      868.30     4341.50\n","2     10569         163         1      513.83      513.83\n","3      2840         479         3      491.82     1475.46\n","4     16232         330         2      231.73      463.46"],"text/html":["\n","  <div id=\"df-d69eb22f-c15c-45f1-95da-01d311ff9565\" class=\"colab-df-container\">\n","    <div>\n","<style scoped>\n","    .dataframe tbody tr th:only-of-type {\n","        vertical-align: middle;\n","    }\n","\n","    .dataframe tbody tr th {\n","        vertical-align: top;\n","    }\n","\n","    .dataframe thead th {\n","        text-align: right;\n","    }\n","</style>\n","<table border=\"1\" class=\"dataframe\">\n","  <thead>\n","    <tr style=\"text-align: right;\">\n","      <th></th>\n","      <th>order_id</th>\n","      <th>product_id</th>\n","      <th>quantity</th>\n","      <th>unit_price</th>\n","      <th>line_total</th>\n","    </tr>\n","  </thead>\n","  <tbody>\n","    <tr>\n","      <th>0</th>\n","      <td>3263</td>\n","      <td>59</td>\n","      <td>3</td>\n","      <td>359.75</td>\n","      <td>1079.25</td>\n","    </tr>\n","    <tr>\n","      <th>1</th>\n","      <td>13187</td>\n","      <td>698</td>\n","  